{
  "name": "@mcd/parser",
  "version": "0.1.0",
  "type": "module",
  "description": "MCD (Markdown CSV Document) parser for TypeScript/JavaScript",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build:wasm": "node scripts/build-wasm.mjs",
    "prebuild": "npm run build:wasm",
    "build": "tsc",
    "pretest": "npm run build:wasm",
    "test": "vitest run",
    "pretypecheck": "npm run build:wasm",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vitest": "^1.0.0",
    "playwright": "^1.40.0"
  },
  "keywords": [
    "mcd",
    "markdown",
    "csv",
    "document",
    "parser"
  ],
  "license": "MIT"
}
