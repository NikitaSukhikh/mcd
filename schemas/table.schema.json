{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mcd-format.org/schemas/table.schema.json",
  "$comment": "SPDX-License-Identifier: CC0-1.0",
  "title": "MCD table schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "columns"],
  "properties": {
    "id": { "$ref": "#/$defs/id" },
    "primaryKey": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/columnName" },
      "uniqueItems": true
    },
    "foreignKeys": {
      "type": "array",
      "items": { "$ref": "#/$defs/foreignKey" }
    },
    "columns": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/column" }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]*$"
    },
    "columnName": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z_][A-Za-z0-9_.-]*$"
    },
    "foreignKey": {
      "type": "object",
      "additionalProperties": false,
      "required": ["columns", "references"],
      "properties": {
        "columns": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/columnName" },
          "uniqueItems": true
        },
        "references": {
          "type": "object",
          "additionalProperties": false,
          "required": ["table", "columns"],
          "properties": {
            "table": { "$ref": "#/$defs/id" },
            "columns": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/columnName" },
              "uniqueItems": true
            }
          }
        }
      }
    },
    "column": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type"],
      "properties": {
        "name": { "$ref": "#/$defs/columnName" },
        "type": {
          "enum": [
            "string",
            "integer",
            "decimal",
            "boolean",
            "date",
            "datetime",
            "time",
            "enum"
          ]
        },
        "label": { "type": "string", "minLength": 1 },
        "nullable": { "type": "boolean" },
        "enumValues": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "values": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "type": { "const": "enum" } },
            "required": ["type"]
          },
          "then": {
            "anyOf": [
              { "required": ["enumValues"], "properties": { "enumValues": { "minItems": 1 } } },
              { "required": ["values"], "properties": { "values": { "minItems": 1 } } }
            ]
          }
        }
      ]
    }
  }
}
