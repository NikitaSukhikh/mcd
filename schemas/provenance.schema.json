{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mcd-format.org/schemas/provenance.schema.json",
  "$comment": "SPDX-License-Identifier: CC0-1.0",
  "title": "MCD provenance metadata",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "sources": {
      "type": "array",
      "items": { "$ref": "#/$defs/source" }
    },
    "actors": {
      "type": "array",
      "items": { "$ref": "#/$defs/actor" }
    },
    "tools": {
      "type": "array",
      "items": { "$ref": "#/$defs/tool" }
    },
    "generatedAssets": {
      "type": "array",
      "items": { "$ref": "#/$defs/generatedAsset" }
    },
    "activities": {
      "type": "array",
      "items": { "$ref": "#/$defs/activity" }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]*$"
    },
    "packagePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(^|/)\\.\\.?($|/))(?!.*[\\\\:])[^/\\\\:]+(?:/[^/\\\\:]+)*$"
    },
    "uri": {
      "type": "string",
      "format": "uri",
      "minLength": 1
    },
    "mediaType": {
      "type": "string",
      "pattern": "^[^\\s/]+/[^\\s]+$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "minLength": 1
    },
    "ref": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "anyOf": [{ "required": ["path"] }, { "required": ["uri"] }],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "path": { "$ref": "#/$defs/packagePath" },
        "uri": { "$ref": "#/$defs/uri" },
        "mediaType": { "$ref": "#/$defs/mediaType" },
        "hash": { "$ref": "#/$defs/sha256" },
        "sizeBytes": { "type": "integer", "minimum": 0 },
        "title": { "type": "string", "minLength": 1 },
        "createdAt": { "$ref": "#/$defs/timestamp" },
        "retrievedAt": { "$ref": "#/$defs/timestamp" }
      }
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "kind": {
          "enum": ["person", "organization", "software", "agent"]
        },
        "name": { "type": "string", "minLength": 1 },
        "uri": { "$ref": "#/$defs/uri" }
      }
    },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "uri": { "$ref": "#/$defs/uri" },
        "hash": { "$ref": "#/$defs/sha256" }
      }
    },
    "generatedAsset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "path": { "$ref": "#/$defs/packagePath" },
        "mediaType": { "$ref": "#/$defs/mediaType" },
        "hash": { "$ref": "#/$defs/sha256" },
        "createdAt": { "$ref": "#/$defs/timestamp" },
        "sourceRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/id" },
          "uniqueItems": true
        },
        "toolRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/id" },
          "uniqueItems": true
        },
        "actorRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/id" },
          "uniqueItems": true
        }
      }
    },
    "activity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "kind": {
          "enum": [
            "authored",
            "imported",
            "extracted",
            "transformed",
            "generated",
            "validated",
            "rendered",
            "reviewed"
          ]
        },
        "startedAt": { "$ref": "#/$defs/timestamp" },
        "endedAt": { "$ref": "#/$defs/timestamp" },
        "actorRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/id" },
          "uniqueItems": true
        },
        "toolRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/id" },
          "uniqueItems": true
        },
        "sourceRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/id" },
          "uniqueItems": true
        },
        "inputRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/ref" },
          "uniqueItems": true
        },
        "outputRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/ref" },
          "uniqueItems": true
        },
        "description": { "type": "string", "minLength": 1 }
      }
    }
  }
}
